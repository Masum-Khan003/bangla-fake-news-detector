# ── HuggingFace ──────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_your_write_token_here
HF_MODEL_REPO=your-username/bangla-fake-news-detector

# ── Weights & Biases ─────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=bangla-fake-news-detector
WANDB_ENTITY=your-wandb-username

# ── API Security ─────────────────────────────────────────
API_SECRET_KEY=generate-a-long-random-string-here
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/predictions.db

# ── Redis (optional locally, required in production) ──────
REDIS_URL=redis://localhost:6379

# ── Model Config ─────────────────────────────────────────
MODEL_NAME=csebuetnlp/banglabert
XLM_MODEL_NAME=xlm-roberta-base
MAX_INPUT_CHARS=10000
CONFIDENCE_THRESHOLD_FAKE=0.72
CONFIDENCE_THRESHOLD_CREDIBLE=0.65

# ── API Config ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_RATE_LIMIT=60/minute
